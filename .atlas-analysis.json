  "keyFeatures": [
    "Point-of-Sale (POS) terminal with barcode scanner workflow",
    "Real-time stock alerts via WebSocket/STOMP",
    "PDF/OCR invoice scanning for automated stock ingestion",
    "Role-based access control (Admin, Empleado, Cliente)",
    "Public e-commerce storefront (Tienda) with cart and order tracking",
    "Admin dashboard with KPIs, sales charts, and cash flow",
    "Inventory management with remito-based goods receipt workflow",
    "Manual stock adjustment with full audit trail",
    "JWT-based stateless authentication",
    "Caffeine-backed caching for catalog performance"
  ],
